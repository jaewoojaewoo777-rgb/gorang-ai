# ==============================
# 고랑AI 환경변수 설정
# ==============================
# 이 파일을 복사해서 .env.local 로 저장하고 값을 채워주세요

# ── Anthropic (Claude AI) ──────────────────
ANTHROPIC_API_KEY=sk-ant-api03-여기에_입력

# ── Google OAuth ───────────────────────────
# Google Cloud Console에서 발급
# https://console.cloud.google.com
GOOGLE_CLIENT_ID=여기에_입력.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-여기에_입력
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/google/callback

# ── Supabase ───────────────────────────────
# https://supabase.com 에서 프로젝트 생성 후 발급
NEXT_PUBLIC_SUPABASE_URL=https://여기에_입력.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ여기에_입력
SUPABASE_SERVICE_ROLE_KEY=eyJ여기에_입력

# ── 세션 암호화 키 (32자 이상 랜덤 문자열) ─
SESSION_SECRET=gorang-ai-session-secret-32-chars-min-here

# ── 앱 URL ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ── Instagram (Meta) ──────────────────────
# Meta Developer Console에서 발급 (앱 심사 후)
INSTAGRAM_APP_ID=여기에_입력
INSTAGRAM_APP_SECRET=여기에_입력

# ── TikTok ────────────────────────────────
# TikTok Developer Console에서 발급 (앱 심사 후)
TIKTOK_CLIENT_KEY=여기에_입력
TIKTOK_CLIENT_SECRET=여기에_입력
